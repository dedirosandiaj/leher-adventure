generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model about {
  id         Int       @id @default(autoincrement())
  content    String?   @default("Leher Adventure adalah komunitas petualangan...")
  updated_at DateTime? @default(now()) @db.Timestamp(6)
}

model admin {
  id       Int     @id @default(autoincrement())
  username String  @unique
  password String
  role     String? @default("admin")
}

model gallery {
  id         Int       @id @default(autoincrement())
  title      String
  image      String
  video_url  String?
  order      Int?      @default(0)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  type       String?   @default("image")
  thumbnail  String?
}

model heroslide {
  id         Int       @id @default(autoincrement())
  image      String
  order      Int?      @default(0)
  created_at DateTime? @default(now()) @db.Timestamp(6)
}

model herotext {
  id          Int       @id @default(autoincrement())
  title_line1 String?   @default("Selamat Datang di")
  title_line2 String?   @default("Leher Adventure")
  description String?   @default("Jelajahi keindahan alam Indonesia bersama kami. Setiap perjalanan adalah cerita yang tak terlupakan.")
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
}

model mountain {
  id         Int      @id @default(autoincrement())
  name       String
  year       Int?     @default(2024)
  status     String?  @default("Rencana")
}

model teammember {
  id    Int     @id @default(autoincrement())
  name  String
  ig    String
  photo String?
}
